# Copy to .env. Both files are gitignored.
# The dashboard runs end-to-end without this key (deterministic stub renders briefings).
# Set it to use the live Anthropic API for briefing generation.
ANTHROPIC_API_KEY=

# Optional. Override the Anthropic model used for briefing generation.
# Leave unset for the project default (claude-haiku-4-5-20251001).
# Examples: claude-sonnet-4-5-20250929, claude-haiku-4-5-20251001
ANTHROPIC_MODEL=

# Data source selector. One of: fixtures (default), csv, salesforce.
DATASOURCE=fixtures

# CSV path — used when DATASOURCE=csv. Defaults to data/csv/.
CSV_DIR=

# Salesforce credentials — used when DATASOURCE=salesforce.
# After clicking "Reset My Security Token" in Salesforce, the token arrives by email.
# SF_DOMAIN: 'login' for production orgs, 'test' for sandboxes.
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=
SF_DOMAIN=login
